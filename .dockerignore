# Dependencias locales (Se vuelven a instalar limpiamente dentro de Docker)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Carpetas de compilación local (Evita conflictos con la compilación de Docker)
.next
out
dist

# Archivos de entorno y credenciales (¡Súper importante por seguridad!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Control de versiones y configuración de editores
.git
.gitignore
.vscode
.idea
.DS_Store

# Documentación innecesaria en producción
README.md
.github